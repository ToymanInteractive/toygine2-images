# Image with the devkitPro devkitPPC toolchain for building ToyGine2 targeting Nintendo Wii.
#
# Thin wrapper over the upstream devkitpro/devkitppc image: pinned to a specific date
# tag and annotated with OCI labels for the toygine2 CI/registry. No extra tooling is
# added — devkitPro already ships the cross-compiler and platform libraries (libogc)
# used by ToyGine2's Makefiles.
#
# Usage (same as the other toygine2 images):
#   docker build -t toygine2-wii -f Dockerfile.wii .
#   docker run --rm -v "$PWD":/workspace -w /workspace toygine2-wii \
#       make -C path/to/project

FROM devkitpro/devkitppc:20260503

LABEL org.opencontainers.image.authors="Toyman Interactive <https://github.com/ToymanInteractive>"
LABEL org.opencontainers.image.url="https://github.com/ToymanInteractive/toygine2-images"
LABEL org.opencontainers.image.documentation="https://github.com/ToymanInteractive/toygine2-images/blob/main/README.md"
LABEL org.opencontainers.image.source="https://github.com/ToymanInteractive/toygine2-images"

LABEL org.opencontainers.image.vendor="Toyman Interactive"
LABEL org.opencontainers.image.licenses="MIT"

LABEL org.opencontainers.image.title="ToyGine2 Wii Toolchain"
LABEL org.opencontainers.image.description="devkitPPC toolchain for building ToyGine2 targeting Nintendo Wii."
LABEL org.opencontainers.image.base.name="docker.io/devkitpro/devkitppc:20260503"
